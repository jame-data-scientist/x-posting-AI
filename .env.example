# ─────────────────────────────────────────────────────────────
# X (Twitter) API Credentials
# Get from: https://developer.x.com/en/portal/dashboard
# App needs Read + Write permissions!
# ─────────────────────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ─────────────────────────────────────────────────────────────
# OpenRouter API Key  (openrouter.ai → Keys)
# Gives access to 300+ models (GPT-4o, Claude, Gemini, Llama, etc.)
# ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─────────────────────────────────────────────────────────────
# Google Gemini API Key  (aistudio.google.com → Get API Key)
# Used when Provider = "Google Gemini" (native Gemini models)
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────
# App Settings
# ─────────────────────────────────────────────────────────────
PROJECT_FOLDER=./project
APP_NAME=Height Leveling
POSTS_PER_DAY=6
